# =========================================================
# Configuration backend MA2E
# Copier vers .env et remplir avec les vraies valeurs.
# JAMAIS commiter .env (déjà dans .gitignore).
# =========================================================

# --- Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# --- Redis
REDIS_URL=redis://HOST:PORT/0

# --- MinIO (stockage des pièces d'identité, chiffré au repos)
MINIO_ENDPOINT=HOST:PORT
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=true   # true en prod, false en local

# --- Auth (JWT)
JWT_SECRET=CHANGE_ME_TO_32_PLUS_RANDOM_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM (Groq) — assistant AYA
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- Mindee OCR (CNI ivoirienne via API v2)
MINDEE_API_KEY=md_xxxxxxxxxxxxxxxxxxxxx
MINDEE_MODEL_ID=

# --- WhatsApp Meta Cloud API
WHATSAPP_VERIFY_TOKEN=ma2e_verify_token_change_me

# --- WhatsApp per-tenant (utilisé par le seed pour peupler la DB)
WHATSAPP_PHONE_ID_MA2E=
WHATSAPP_ACCESS_TOKEN_MA2E=
WABA_ID_MA2E=

# --- Telegram (facultatif)
TELEGRAM_TOKEN_MA2E=

# --- Azure OpenAI Embeddings (RAG, text-embedding-3-small, 1536 dims)
AZURE_OPENAI_EMBEDDING=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/text-embedding-3-small/embeddings?api-version=2023-05-15
AZURE_OPENAI_API_KEY_EMBEDDING=

# --- App
APP_ENV=production
APP_BASE_URL=https://api.ma2e.ci
PUBLIC_WEBHOOK_URL=https://api.ma2e.ci
