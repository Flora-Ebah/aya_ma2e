# Python (backend)
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.python-version

# =========================================================
# Node.js / Next.js (frontend)
# =========================================================
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
.npm
.eslintcache

# =========================================================
# IDE & OS
# =========================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
.claude/

